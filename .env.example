# Copy this file to .env and fill in your values
# Never commit .env to git

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Embeddings model (local — no key needed)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ChromaDB
CHROMA_PERSIST_DIR=./data/processed
CHROMA_COLLECTION=retrieval_agent

# Chunk settings
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Retrieval
TOP_K=5

# Observability (Week 3 — optional for now)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
